{
  "agents": {
    "defaults": {
      "workspace": "/path/to/your/workspace",
      "models": {
        "your-provider/your-model": {
          "alias": "YourModel"
        }
      },
      "model": {
        "primary": "your-provider/your-model"
      }
    },
    "list": [
      {
        "id": "main"
      },
      {
        "id": "wiki-manager",
        "name": "wiki-manager",
        "workspace": "/path/to/your/agents/wiki-manager/workspace",
        "agentDir": "/path/to/your/.openclaw/agents/wiki-manager/agent",
        "model": "your-provider/your-model"
      },
      {
        "id": "qa-bot",
        "name": "qa-bot",
        "workspace": "/path/to/your/agents/qa-bot/workspace",
        "agentDir": "/path/to/your/.openclaw/agents/qa-bot/agent",
        "model": "your-provider/your-model"
      }
    ]
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "YOUR_GATEWAY_TOKEN"
    },
    "port": 18789,
    "bind": "loopback",
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "controlUi": {
      "allowInsecureAuth": true
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send",
        "sms.search"
      ]
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "skills": {
    "load": {
      "extraDirs": [
        "/path/to/your/agents/qa-bot/workspace/skills",
        "/path/to/your/agents/wiki-manager/workspace/skills"
      ],
      "watch": true,
      "watchDebounceMs": 250
    }
  },
  "tools": {
    "profile": "coding",
    "web": {
      "search": {
        "provider": "your-search-provider",
        "enabled": true
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "your-provider": {
        "baseUrl": "https://api.your-provider.com/v1/",
        "api": "anthropic-messages",
        "models": [
          {
            "id": "your-model",
            "name": "Your Model",
            "reasoning": true,
            "input": [
              "text",
              "image"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 262144,
            "maxTokens": 32768
          }
        ]
      }
    }
  },
  "auth": {
    "profiles": {
      "default": {
        "provider": "your-provider",
        "mode": "api_key"
      }
    }
  },
  "channels": {
    "feishu": {
      "enabled": true,
      "appId": "YOUR_FEISHU_APP_ID",
      "appSecret": "YOUR_FEISHU_APP_SECRET",
      "connectionMode": "websocket",
      "domain": "feishu",
      "dmPolicy": "open",
      "groupPolicy": "open",
      "requireMention": true
    }
  },
  "plugins": {
    "entries": {
      "web-search": {
        "enabled": true,
        "config": {
          "webSearch": {
            "apiKey": "YOUR_WEB_SEARCH_API_KEY"
          }
        }
      },
      "your-provider": {
        "enabled": true
      }
    }
  },
  "wizard": {
    "lastRunAt": "2026-04-25T10:23:08.809Z",
    "lastRunVersion": "2026.4.23",
    "lastRunCommand": "onboard",
    "lastRunMode": "local"
  },
  "meta": {
    "lastTouchedVersion": "2026.4.23",
    "lastTouchedAt": "2026-05-06T09:34:58.360Z"
  },
  "bindings": [
    {
      "type": "route",
      "agentId": "qa-bot",
      "match": {
        "channel": "feishu"
      }
    }
  ]
}
