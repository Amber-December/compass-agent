# Environment setup tools (not part of robot core code)
# tools/ 已取消忽略 — wiki_ingest.py / wiki_query.py / build_graph.py 为核心协作脚本
# tools/

# Environment variables
.env

# Node modules
node_modules/

# Data files (generated)
data/raw/
data/mock/
data/*.db

# Logs
logs/
*.log

# OS files
.DS_Store

# OpenClaw runtime
.openclaw/

# Sensitive configs (use .example templates instead)
accounts.json
openclaw.json
workspace/openclaw.json

# Wiki local index cache
wiki/sources/*.md.tmp
wiki/.cache/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Agent self-improving learnings (runtime generated)
workspace/.learnings/

# Local directories (not committed)
database/
eval/
scripts/
demo/docs/
workspace/agents.bak.*/
workspace/memory/

# Knowledge base — preserve directory structure, ignore all generated content
workspace/knowledge/**/*
!workspace/knowledge/**/.gitkeep

# Wiki manager workspace — keep structure with .gitkeep, ignore runtime content
agents/wiki-manager/workspace/raw_lark/*
!agents/wiki-manager/workspace/raw_lark/.gitkeep
agents/wiki-manager/workspace/data
agents/wiki-manager/workspace/graph
agents/wiki-manager/workspace/wiki
agents/wiki-manager/workspace/state/*
!agents/wiki-manager/workspace/state/.gitkeep
# Config: keep structure + example template, ignore actual config files
agents/wiki-manager/workspace/config/*
!agents/wiki-manager/workspace/config/.gitkeep
!agents/wiki-manager/workspace/config/*.example
